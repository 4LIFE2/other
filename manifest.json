{
  "manifest_version": 3,
  "name": "Interaction Recorder",
  "version": "0.1.0",
  "description": "Records browser interactions (clicks, inputs, navigations, waits) for later automation playback or codegen.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs",
    "downloads",
    "webNavigation",
    "webRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Interaction Recorder"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
